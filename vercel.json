{
  "buildCommand": "cd artifacts/library-app && vite build",
  "outputDirectory": "artifacts/library-app/dist/public",
  "framework": "vite",
  "env": {
    "PORT": "3000",
    "BASE_PATH": "/"
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://library-api-drze.onrender.com/api/$1" }
  ]
}
